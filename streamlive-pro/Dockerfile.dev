FROM mcr.microsoft.com/playwright:v1.50.1-noble

# Set environment variables to avoid user prompts during apt installations
ENV DEBIAN_FRONTEND=noninteractive
# Set to english locale
ENV LANG=en_US.UTF-8

# Install dependencies for Xvfb, VNC, noVNC, window manager (fluxbox), and FFmpeg
RUN apt-get update && apt-get install -y --no-install-recommends \
    xvfb \
    x11vnc \
    novnc \
    websockify \
    fluxbox \
    ffmpeg \
    supervisor \
    x11-xserver-utils \
    net-tools \
    python3 \
    python3-pip \
    python3-websockify \
    git \
    nano \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# The entrypoint script will be mapped from the host to ensure it's easy to modify
# However, we'll ensure we have a fallback if not provided via compose
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Expose noVNC port (8080 by default) and Vite port (5173 for HMR if needed)
EXPOSE 8080 5173

# Entrypoint script will run all necessary background services before starting the app
ENTRYPOINT ["/entrypoint.sh"]
